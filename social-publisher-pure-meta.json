                        {
                            "name": "access_token",
                            "value": "={{ $('Prepare Days + Credentials').item.json.accessToken }}"
                        }
                    ]
                },
                "options": {}
            },
            "id": "ig-publish",
            "name": "IG Publish Media",
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4.2,
            "position": [
                700,
                250
            ]
        },
        {
            "parameters": {
                "jsCode": "// Aggregate results from both FB and IG\nreturn [{\n  json: {\n    status: 'success',\n    message: 'Posted to Facebook and Instagram (Pure Meta V3)',\n    timestamp: new Date().toISOString()\n  }\n}];"
            },
            "id": "respond-success",
