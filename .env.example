# ==================================
# SYNERGOS V3 - Environment Variables
# ==================================

# N8N Server (for AgentSyn, TranscripSyn, MarketSyn)
# Your N8N server URL and webhooks are configured in synergos-config.ts

# ==================================
# IMAGE/VIDEO GENERATION (Optional)
# ==================================
# Configure at least one for AI image generation
# If none configured, fallback placeholder images will be used

# Kling AI (AK/SK for JWT auth - get from https://kling.ai)
KLING_ACCESS_KEY=
KLING_SECRET_KEY=

# Flux via OpenRouter (get from https://openrouter.ai)
OPENROUTER_API_KEY=

# ==================================
# SUPABASE (for authentication)
# ==================================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ==================================
# NEON DATABASE (PWA Engine)
# ==================================
DATABASE_URL=postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require

# ==================================
# WEB PUSH (VAPID Keys)
# ==================================
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:your@email.com
